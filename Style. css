/* Reset default styles */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* Body styling */
body {
    font-family: Arial, sans-serif;
    background-color: #f5f5f5;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
}

/* Logo */
.logo-container {
    margin-top: 50px;
    margin-bottom: 50px;
}
.logo {
    width: 200px;
    height: auto;
    border-radius: 10px;
}

/* Option Boxes */
.options-container {
    display: flex;
    gap: 30px;
    flex-wrap: wrap;
    justify-content: center;
}

.option-box {
    background-color: #007bff;
    color: white;
    padding: 40px 60px;
    border-radius: 12px;
    text-align: center;
    font-size: 20px;
    cursor: pointer;
    transition: transform 0.2s, background-color 0.2s;
}

.option-box:hover {
    background-color: #0056b3;
    transform: scale(1.05);
}
